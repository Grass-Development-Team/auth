# Enforce LF line endings for all text files in this repository.
* text=auto eol=lf

# Common Windows script formats that require CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Keep binary assets untouched.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.zip binary
*.gz binary
*.wasm binary
